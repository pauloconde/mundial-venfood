---
import Layout from '../layouts/Layout.astro';
import {
  fetchWorldCupData,
  getNextMatch,
  getMatchesForDate,
  parseMatchDate,
  hasScore,
  getScoreString,
  getFlagUrl,
  getMatchUTC,
  translateTeam,
  translateGround,
  translateGroup,
} from '../lib/worldcup';

const data = await fetchWorldCupData();
const now  = new Date();

// ── Próximo partido ──
const nextMatch = getNextMatch(data, now);

// ── Partidos de hoy (fecha local del usuario — se ajusta con JS en cliente) ──
// Usamos la fecha UTC actual como aproximación para el SSR.
// El cliente puede ajustar si es necesario.
const todayStr = `${now.getUTCFullYear()}-${String(now.getUTCMonth() + 1).padStart(2, '0')}-${String(now.getUTCDate()).padStart(2, '0')}`;
const todayMatches = getMatchesForDate(data, todayStr);

// ── Si no hay partidos hoy, mostrar los siguientes 8 ──
let carouselMatches = todayMatches;
if (carouselMatches.length === 0) {
  carouselMatches = data.matches
    .map(m => ({ m, d: parseMatchDate(m.date, m.time) }))
    .filter(({ d }) => d > now)
    .sort((a, b) => a.d.getTime() - b.d.getTime())
    .slice(0, 8)
    .map(({ m }) => m);
}

const nextMatchUTC = nextMatch ? getMatchUTC(nextMatch) : null;
---

<Layout title="Inicio" page="home">

  <!-- ── Hero: Próximo Partido ── -->
  {nextMatch ? (
    <section class="hero-bg relative px-4 pt-8 pb-10 overflow-hidden">
      <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="absolute -top-20 -right-20 w-64 h-64 rounded-full opacity-10"
             style="background: radial-gradient(circle, #f59e0b, transparent 70%);"></div>
        <div class="absolute -bottom-10 -left-10 w-48 h-48 rounded-full opacity-10"
             style="background: radial-gradient(circle, #6366f1, transparent 70%);"></div>
      </div>

      <div class="relative z-10 max-w-lg mx-auto">
        <!-- Etiqueta -->
        <div class="flex items-center gap-2 mb-6">
          <div class="flex gap-1 items-center px-3 py-1 rounded-full text-xs font-bold tracking-wider"
               style="background: rgba(245,158,11,0.15); border: 1px solid rgba(245,158,11,0.3); color: #f59e0b;">
            ⚡ PRÓXIMO PARTIDO
          </div>
          {nextMatch.group && (
            <span class="text-xs text-[var(--text-secondary)] font-semibold">{translateGroup(nextMatch.group)}</span>
          )}
        </div>

        <!-- Tarjeta del partido -->
        <div class="glass rounded-3xl p-6 slide-up">
          <div class="flex items-center justify-between gap-4">

            <!-- Equipo 1 -->
            <div class="flex-1 flex flex-col items-center gap-2 text-center">
              <img
                src={getFlagUrl(nextMatch.team1)}
                alt={translateTeam(nextMatch.team1)}
                class="w-14 h-10 object-cover rounded-lg shadow-lg"
                onerror="this.style.display='none'"
              />
              <span class="font-bold text-sm leading-tight">{translateTeam(nextMatch.team1)}</span>
            </div>

            <!-- Centro: marcador o hora -->
            <div class="flex flex-col items-center gap-1 px-4">
              {hasScore(nextMatch) ? (
                <span class="font-['Outfit'] font-black text-3xl gradient-text">
                  {getScoreString(nextMatch)}
                </span>
              ) : (
                <div class="text-center">
                  <!-- Hora local: el script del layout la convierte -->
                  <p class="font-['Outfit'] font-black text-2xl text-[var(--text-primary)]">
                    <time data-utc={nextMatchUTC} data-fmt="time">--:--</time>
                  </p>
                  <p class="text-xs text-[var(--text-secondary)] mt-1">
                    <time data-utc={nextMatchUTC} data-fmt="date">…</time>
                  </p>
                </div>
              )}
            </div>

            <!-- Equipo 2 -->
            <div class="flex-1 flex flex-col items-center gap-2 text-center">
              <img
                src={getFlagUrl(nextMatch.team2)}
                alt={translateTeam(nextMatch.team2)}
                class="w-14 h-10 object-cover rounded-lg shadow-lg"
                onerror="this.style.display='none'"
              />
              <span class="font-bold text-sm leading-tight">{translateTeam(nextMatch.team2)}</span>
            </div>

          </div>

          <!-- Sede -->
          <div class="mt-5 flex items-center justify-center gap-2 text-[var(--text-secondary)]">
            <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <circle cx="12" cy="11" r="3"/>
            </svg>
            <span class="text-xs font-medium truncate">{translateGround(nextMatch.ground)}</span>
          </div>
        </div>

        <!-- Cuenta regresiva (animada por JS) -->
        {nextMatchUTC && !hasScore(nextMatch) && (
          <div class="mt-4 grid grid-cols-4 gap-2">
            {['días', 'hrs', 'min', 'seg'].map(label => (
              <div class="flex flex-col items-center glass rounded-2xl py-3">
                <span id={`cd-${label}`} class="font-['Outfit'] font-black text-2xl text-amber-400">--</span>
                <span class="text-[9px] text-[var(--text-secondary)] font-semibold uppercase tracking-wider mt-0.5">{label}</span>
              </div>
            ))}
          </div>
          <script define:vars={{ targetISO: nextMatchUTC }}>
            (function () {
              const target = new Date(targetISO);
              function update() {
                const diff = target - Date.now();
                if (diff <= 0) return;
                const d = Math.floor(diff / 86400000);
                const h = Math.floor((diff % 86400000) / 3600000);
                const m = Math.floor((diff % 3600000) / 60000);
                const s = Math.floor((diff % 60000) / 1000);
                const el = id => document.getElementById('cd-' + id);
                if (el('días')) el('días').textContent = String(d).padStart(2, '0');
                if (el('hrs'))  el('hrs').textContent  = String(h).padStart(2, '0');
                if (el('min'))  el('min').textContent  = String(m).padStart(2, '0');
                if (el('seg'))  el('seg').textContent  = String(s).padStart(2, '0');
              }
              update();
              setInterval(update, 1000);
            })();
          </script>
        )}
      </div>
    </section>
  ) : (
    <section class="hero-bg px-4 pt-8 pb-10 text-center">
      <div class="glass rounded-3xl p-8 max-w-lg mx-auto">
        <p class="text-5xl mb-4">🏁</p>
        <h2 class="font-['Outfit'] font-black text-2xl gradient-text">Torneo Finalizado</h2>
        <p class="text-[var(--text-secondary)] mt-2">Revisa los resultados en el Calendario</p>
      </div>
    </section>
  )}

  <!-- ── Carrusel ── -->
  <section class="mt-8 max-w-lg mx-auto">
    <div class="flex items-center justify-between px-4 mb-4">
      <h2 class="font-['Outfit'] font-bold text-lg text-[var(--text-primary)]">
        {todayMatches.length > 0 ? '📅 Partidos de Hoy' : '⏭️ Próximos Partidos'}
      </h2>
      <a href="/calendario" class="text-xs font-semibold text-amber-400 flex items-center gap-1">
        Ver todos
        <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    {carouselMatches.length > 0 ? (
      <div class="carousel-track">
        {carouselMatches.map(match => {
          const utc = getMatchUTC(match);
          return (
            <div class="carousel-item w-64">
              <div class="match-card p-4 h-full">
                {match.group && (
                  <div class="mb-3">
                    <span class="text-[10px] font-bold px-2 py-0.5 rounded-full"
                          style="background: rgba(255,255,255,0.1); color: #ffffff; border: 1px solid rgba(255,255,255,0.25);">
                      {translateGroup(match.group)}
                    </span>
                  </div>
                )}

                <div class="flex items-center justify-between gap-2">
                  <div class="flex-1 flex flex-col items-center gap-1.5">
                    <img src={getFlagUrl(match.team1)} alt={translateTeam(match.team1)}
                         class="w-10 h-7 object-cover rounded shadow"
                         onerror="this.style.display='none'" />
                    <span class="text-xs font-bold text-center leading-tight">{translateTeam(match.team1)}</span>
                  </div>

                  <div class="flex flex-col items-center px-2">
                    {hasScore(match) ? (
                      <span class="font-['Outfit'] font-black text-xl gradient-text">{getScoreString(match)}</span>
                    ) : (
                      <div class="text-center">
                        <p class="font-['Outfit'] font-bold text-base text-amber-400">
                          <time data-utc={utc} data-fmt="time">--:--</time>
                        </p>
                        <p class="text-[9px] text-[var(--text-secondary)] mt-0.5">
                          <time data-utc={utc} data-fmt="date-short">…</time>
                        </p>
                      </div>
                    )}
                  </div>

                  <div class="flex-1 flex flex-col items-center gap-1.5">
                    <img src={getFlagUrl(match.team2)} alt={translateTeam(match.team2)}
                         class="w-10 h-7 object-cover rounded shadow"
                         onerror="this.style.display='none'" />
                    <span class="text-xs font-bold text-center leading-tight">{translateTeam(match.team2)}</span>
                  </div>
                </div>

                <div class="mt-3 flex items-center gap-1.5 text-[var(--text-secondary)]">
                  <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <circle cx="12" cy="11" r="3"/>
                  </svg>
                  <span class="text-[10px] truncate">{translateGround(match.ground)}</span>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    ) : (
      <div class="mx-4 glass rounded-2xl p-6 text-center">
        <p class="text-[var(--text-secondary)]">No hay partidos programados para hoy</p>
      </div>
    )}
  </section>

  <!-- ── Estadísticas rápidas ── -->
  <section class="mt-8 px-4 max-w-lg mx-auto">
    <div class="grid grid-cols-3 gap-3">
      <div class="glass rounded-2xl p-4 text-center">
        <p class="font-['Outfit'] font-black text-2xl gradient-text">104</p>
        <p class="text-[10px] text-[var(--text-secondary)] mt-1 font-semibold">PARTIDOS</p>
      </div>
      <div class="glass rounded-2xl p-4 text-center">
        <p class="font-['Outfit'] font-black text-2xl gradient-text">48</p>
        <p class="text-[10px] text-[var(--text-secondary)] mt-1 font-semibold">EQUIPOS</p>
      </div>
      <div class="glass rounded-2xl p-4 text-center">
        <p class="font-['Outfit'] font-black text-2xl gradient-text">16</p>
        <p class="text-[10px] text-[var(--text-secondary)] mt-1 font-semibold">SEDES</p>
      </div>
    </div>
  </section>

  <!-- ── Países sede ── -->
  <section class="mt-6 px-4 pb-4 max-w-lg mx-auto">
    <h2 class="font-['Outfit'] font-bold text-lg mb-4">🌎 Países Sede</h2>
    <div class="grid grid-cols-3 gap-3">
      {[
        { flag: '🇲🇽', name: 'México',         venues: '3 sedes' },
        { flag: '🇺🇸', name: 'Estados Unidos', venues: '11 sedes' },
        { flag: '🇨🇦', name: 'Canadá',         venues: '2 sedes' },
      ].map(c => (
        <div class="glass rounded-2xl p-3 text-center hover:border-amber-400/30 transition-colors border border-transparent">
          <span class="text-3xl">{c.flag}</span>
          <p class="text-xs font-bold mt-2 leading-tight">{c.name}</p>
          <p class="text-[10px] text-[var(--text-secondary)] mt-1">{c.venues}</p>
        </div>
      ))}
    </div>
  </section>

</Layout>
