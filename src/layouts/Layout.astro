    <!-- ── Script: Drawer + PWA Install ── -->
    <script is:inline>
      (function () {
        var panel    = document.getElementById('drawer-panel');
        var backdrop = document.getElementById('drawer-backdrop');
        var btnOpen  = document.getElementById('drawer-open');
        var btnClose = document.getElementById('drawer-close');
        var deferredPrompt = null;

        function openDrawer() {
          backdrop.style.display = 'block';
          requestAnimationFrame(function () {
            backdrop.style.opacity = '1';
            panel.style.transform  = 'translateX(0)';
          });
          document.body.style.overflow = 'hidden';
        }

        function closeDrawer() {
          backdrop.style.opacity = '0';
          panel.style.transform  = 'translateX(100%)';
          setTimeout(function () {
            backdrop.style.display = 'none';
            document.body.style.overflow = '';
          }, 350);
        }

        btnOpen.addEventListener('click', openDrawer);
        btnClose.addEventListener('click', closeDrawer);
        backdrop.addEventListener('click', closeDrawer);
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') closeDrawer();
        });

        // ── PWA Install: Android ──
        var section = document.getElementById('install-android');
        var headerBtn = document.getElementById('header-install-btn');
        
        // Mostrar SOLO si el navegador permite la instalación automática
        if (window.deferredPrompt) {
          if (section) section.style.display = 'block';
          if (headerBtn) headerBtn.style.display = 'flex';
        }

        function handleInstallClick() {
          if (!window.deferredPrompt) return;
          window.deferredPrompt.prompt();
          window.deferredPrompt.userChoice.then(function () {
            window.deferredPrompt = null;
            if (section) section.style.display = 'none';
            if (headerBtn) headerBtn.style.display = 'none';
          });
        }

        var installBtn = document.getElementById('install-btn');
        if (installBtn) installBtn.addEventListener('click', handleInstallClick);
        if (headerBtn) headerBtn.addEventListener('click', handleInstallClick);

        // ── PWA Install: iOS (Safari) ──
        var isIOS    = /iphone|ipad|ipod/i.test(navigator.userAgent);
        var isSafari = /safari/i.test(navigator.userAgent) && !/chrome/i.test(navigator.userAgent);
        var isStandalone = ('standalone' in window.navigator) && window.navigator.standalone;
        
        var iosModalBackdrop = document.getElementById('ios-modal-backdrop');
        var iosModalPanel = document.getElementById('ios-modal-panel');
        var iosModalClose = document.getElementById('ios-modal-close');

        function openIosModal() {
          if (!iosModalBackdrop) return;
          iosModalBackdrop.style.display = 'flex';
          requestAnimationFrame(function () {
            iosModalBackdrop.style.opacity = '1';
            iosModalPanel.style.transform = 'scale(1)';
          });
          document.body.style.overflow = 'hidden';
        }

        function closeIosModal() {
          if (!iosModalBackdrop) return;
          iosModalBackdrop.style.opacity = '0';
          iosModalPanel.style.transform = 'scale(0.95)';
          setTimeout(function () {
            iosModalBackdrop.style.display = 'none';
            document.body.style.overflow = '';
          }, 300);
        }

        if (iosModalClose) iosModalClose.addEventListener('click', closeIosModal);
        if (iosModalBackdrop) {
          iosModalBackdrop.addEventListener('click', function(e) {
            if (e.target === iosModalBackdrop) closeIosModal();
          });
        }

        if (isIOS && isSafari && !isStandalone) {
          var iosSection = document.getElementById('install-ios');
          if (iosSection) iosSection.style.display = 'block';
          
          if (headerBtn) {
            headerBtn.style.display = 'flex';
            headerBtn.removeEventListener('click', handleInstallClick);
            headerBtn.addEventListener('click', openIosModal);
          }
        }
      })();
    </script>

